# Application
PORT=3000
NODE_ENV=development

# AWS
AWS_REGION=eu-west-3

# AWS Cognito
COGNITO_USER_POOL_ID=eu-west-3_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# DynamoDB Tables
DYNAMODB_USERS_TABLE=bball-app-user-service-users-nonlive
DYNAMODB_TEAMS_STATIC_TABLE=bball-app-data-consumption-teams-static-nonlive

# Cache TTL (seconds)
CACHE_TTL=60

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
