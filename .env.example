# Application
PORT=3000
NODE_ENV=development

# AWS
AWS_REGION=eu-west-3

# Local Development Endpoints (leave empty for real AWS)
# Uncomment these when running with docker-compose --profile local
AWS_DYNAMODB_ENDPOINT=http://dynamodb-local:8000
AWS_COGNITO_ENDPOINT=http://cognito-local:9229

# AWS Cognito
# For local development, use these placeholder values:
# COGNITO_USER_POOL_ID=local_XXXXXX
# COGNITO_CLIENT_ID=local-client-id
# For AWS, use real values:
COGNITO_USER_POOL_ID=eu-west-3_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# DynamoDB Tables
# For local development:
# DYNAMODB_USERS_TABLE=bball-app-user-service-users-local
# DYNAMODB_TEAMS_TABLE=bball-app-user-service-teams-local
# For AWS:
DYNAMODB_USERS_TABLE=bball-app-user-service-users-nonlive
DYNAMODB_TEAMS_TABLE=bball-app-user-service-teams-nonlive

# Cache TTL (seconds)
CACHE_TTL=60

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
